+
+  .task-form-section[open] summary { border-bottom: 1px solid var(--border); }
+  .task-form-section > :not(summary) { margin-left: 14px; margin-right: 14px; }
+  .task-form-section > :last-child { margin-bottom: 14px; }
+  .task-form-section > .grid { margin-top: 14px; }
+  .task-form-section > div + div { margin-top: 14px; }
+
+  .task-form-section .flex.gap-2 { gap: 8px; }
+  .task-form-section .flex.gap-2 > button { min-width: 48px; min-height: 40px; }
+  .task-form-section .flex.flex-wrap { gap: 8px; margin-top: 10px; }
+
+  .task-form-section .max-h-24 {
+    max-height: 72px;
+    padding: 6px;
+  }
+
+  /* Turn the desktop density task rows into independently tappable mobile cards. */
+  .task-list {
+    background: transparent;
+    border: 0;
+    overflow: visible;
+  }
+
+  .task-row {
+    align-items: flex-start;
+    min-height: 84px;
+    margin-bottom: 10px;
+    padding: 14px;
+    border: 1px solid var(--border);
+    border-radius: 16px;
+    background: var(--card);
+    box-shadow: 0 1px 2px rgb(0 0 0 / .04);
+  }
+
+  .task-row > div:first-child { min-width: 0; gap: 10px; }
+  .task-row input[type="checkbox"] { width: 20px; height: 20px; flex: 0 0 auto; }
+  .task-row > div:last-child { gap: 6px; padding-left: 8px; }
+  .task-row > div:last-child > span:nth-child(2) { display: none; }
+  .task-row .task-actions { opacity: 1; }
+  .task-row button { min-width: 36px; min-height: 36px; }
+
+  @keyframes mobile-pop-in { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
+  @keyframes mobile-sheet-in { from { transform: translateY(32px); } to { transform: translateY(0); } }
+}
+
+@media (min-width: 768px) {
+  .task-form-section { display: contents; }
+  .task-form-section > summary { display: none; }
+}
